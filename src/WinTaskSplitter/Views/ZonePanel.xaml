<UserControl x:Class="WinTaskSplitter.Views.ZonePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTaskSplitter.ViewModels"
             AllowDrop="True">

    <Border Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
            BorderBrush="{Binding BorderColor, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="{Binding BorderThickness}">

        <!-- Zone context menu (right-click on empty bar area) -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{Binding Name}" IsEnabled="False" FontWeight="Bold"/>
                <Separator/>
                <MenuItem Header="Zone bearbeiten..." Click="EditZone_Click"/>
                <Separator/>
                <MenuItem Header="Neue Zone hinzufügen" Click="AddZone_Click"/>
                <MenuItem Header="Zone löschen"         Click="DeleteZone_Click"/>
                <Separator/>
                <MenuItem Header="Einstellungen..."     Click="OpenSettings_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <DockPanel LastChildFill="True">

            <!-- Start button (shown in whichever zone is configured) -->
            <Button DockPanel.Dock="Left"
                    Width="40" Height="40" Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Start-Menü"
                    Visibility="{Binding ShowStartButton,
                                 Converter={StaticResource BoolToVisibilityConverter}}"
                    Command="{Binding DataContext.OpenStartMenuCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#55FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="⊞" FontSize="20" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <!-- Zone name: left-docked, vertically centered, with separator -->
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowLabel,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding Name}"
                           FontSize="{Binding DataContext.LabelFontSize,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="#88FFFFFF"
                           VerticalAlignment="Center"
                           Margin="5,0,6,0"/>
                <Rectangle Width="1" Fill="#44FFFFFF" Margin="0,6"/>
            </StackPanel>

            <!-- Icons fill remaining space, vertically centered -->
            <ItemsControl DockPanel.Dock="Left"
                          ItemsSource="{Binding Apps}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:AppItemViewModel}">
                        <Button Width="40" Height="40"
                                Margin="2,0"
                                ToolTip="{Binding Title}"
                                Tag="{Binding}"
                                Command="{Binding ActivateCommand}"
                                PreviewMouseMove="AppButton_PreviewMouseMove"
                                PreviewMouseRightButtonUp="AppButton_RightClick">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"   Value="Transparent"/>
                                    <Setter Property="BorderBrush"  Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding"      Value="4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"  Value="#33FFFFFF"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#55FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background"  Value="#44FFFFFF"/>
                                            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <!-- Icon or fallback initial -->
                            <Grid Width="30" Height="30">
                                <Image Source="{Binding Icon}"
                                       Width="30" Height="30"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding Icon,
                                                    Converter={StaticResource NullToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding ProcessName[0]}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#CCFFFFFF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Icon,
                                                        Converter={StaticResource NullToInverseVisibilityConverter}}"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </DockPanel>
    </Border>
</UserControl>
