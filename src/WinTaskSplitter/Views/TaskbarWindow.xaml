<Window x:Class="WinTaskSplitter.Views.TaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinTaskSplitter.Views"
        xmlns:vm="clr-namespace:WinTaskSplitter.ViewModels"
        Title="WinTaskSplitter"
        Height="56"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <DockPanel LastChildFill="True">

        <!-- System zone: tray icons + status icons + clock, docked right (sizes to content) -->
        <views:SystemZonePanel x:Name="SystemZonePanelControl"
                               DockPanel.Dock="Right"
                               MinWidth="190"
                               DataContext="{Binding SystemZone}"/>

        <!-- All user zones (incl. Allgemein): resizable via GridSplitter — built in code-behind -->
        <Grid x:Name="ZonesGrid"/>

    </DockPanel>
</Window>
