<Window x:Class="WinTaskSplitter.Views.ZoneEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone bearbeiten"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1E1E1E"
        Foreground="White">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#CCCCCC"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,10,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="#FF2D2D2D"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#FF555555"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin"     Value="0,8,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Name -->
        <TextBlock Text="Zone Name"/>
        <TextBox x:Name="NameBox"/>

        <!-- Label sichtbar -->
        <CheckBox x:Name="ShowLabelBox" Content="Zonen-Label anzeigen" Margin="0,10,0,0"/>

        <!-- Hintergrundfarbe -->
        <TextBlock Text="Hintergrundfarbe (Hex, z.B. #FF202020)"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="BgColorBox" Grid.Column="0" TextChanged="ColorBox_TextChanged"/>
            <Border x:Name="BgPreview" Grid.Column="1" Width="28" Height="28"
                    Margin="6,0,0,0" CornerRadius="4" BorderThickness="1"
                    BorderBrush="#FF555555" VerticalAlignment="Center"/>
        </Grid>

        <!-- Rahmenfarbe -->
        <TextBlock Text="Rahmenfarbe (Hex, z.B. #FF3A3A3A)"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="BorderColorBox" Grid.Column="0" TextChanged="ColorBox_TextChanged"/>
            <Border x:Name="BorderPreview" Grid.Column="1" Width="28" Height="28"
                    Margin="6,0,0,0" CornerRadius="4" BorderThickness="1"
                    BorderBrush="#FF555555" VerticalAlignment="Center"/>
        </Grid>

        <!-- Breite (relative Gewichtung) -->
        <TextBlock Text="Breite (relative Gewichtung, Standard: 200)"/>
        <TextBox x:Name="WidthBox"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Übernehmen" Click="Apply_Click" Margin="0,0,8,0"
                    Background="#FF2A5A2A"/>
            <Button Content="Abbrechen"  Click="Cancel_Click"
                    Background="#FF3A3A3A"/>
        </StackPanel>
    </StackPanel>
</Window>
