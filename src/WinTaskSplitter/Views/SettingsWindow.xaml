<Window x:Class="WinTaskSplitter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinTaskSplitter.ViewModels"
        Title="WinTaskSplitter – Einstellungen"
        Width="700" SizeToContent="Height"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#FF1A1A1A"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#888888"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#CCCCCC"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#FF2D2D2D"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="5,3"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="#FF2D2D2D"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background"  Value="#FF1E4A1E"/>
            <Setter Property="BorderBrush" Value="#FF2A6A2A"/>
            <Setter Property="Padding"     Value="16,7"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Padding"  Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- ── Allgemein ────────────────────────────────────────────── -->
        <TextBlock Text="ALLGEMEIN" Style="{StaticResource SectionHeader}"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Label-Schriftgröße"
                       Style="{StaticResource FieldLabel}"/>
            <Slider x:Name="FontSizeSlider" Grid.Column="1"
                    Minimum="7" Maximum="32"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    Value="{Binding LabelFontSize}"
                    ValueChanged="FontSizeSlider_ValueChanged"/>
            <TextBlock x:Name="FontSizeLabel" Grid.Column="2"
                       Foreground="White" FontSize="12"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>

        <!-- Start-Schaltfläche -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Start-Schaltfläche in"
                       Style="{StaticResource FieldLabel}"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Zones}"
                      SelectedItem="{Binding StartButtonZone, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Background="#FF2D2D2D"
                      Foreground="White"
                      BorderBrush="#FF444444"
                      BorderThickness="1"/>
        </Grid>

        <!-- ── Separator ─────────────────────────────────────────────── -->
        <Rectangle Height="1" Fill="#FF333333" Margin="0,16"/>

        <!-- ── Zonen ──────────────────────────────────────────────────── -->
        <TextBlock Text="ZONEN" Style="{StaticResource SectionHeader}"/>

        <!-- Zone list header -->
        <Grid Margin="0,0,0,4" Height="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Reihenf." Foreground="#777777" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Name"     Foreground="#777777" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBlock Grid.Column="2" Text="Label"    Foreground="#777777" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Hintergrund" Foreground="#777777" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBlock Grid.Column="4" Text="Rahmen"   Foreground="#777777" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBlock Grid.Column="5" Text="Breite"   Foreground="#777777" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <Rectangle Height="1" Fill="#FF2A2A2A" Margin="0,0,0,4"/>

        <!-- Zone rows -->
        <ItemsControl x:Name="ZoneList" ItemsSource="{Binding Zones}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ZoneViewModel}">
                    <Grid Margin="0,3" Height="34">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>

                        <!-- Reihenfolge -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="26" Height="26" Content="▲"
                                    Style="{StaticResource IconButton}"
                                    Tag="{Binding}"
                                    Click="MoveUp_Click"/>
                            <Button Width="26" Height="26" Content="▼"
                                    Style="{StaticResource IconButton}"
                                    Tag="{Binding}"
                                    Click="MoveDown_Click"
                                    Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- Name -->
                        <TextBox Grid.Column="1"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Margin="4,0"/>

                        <!-- ShowLabel -->
                        <CheckBox Grid.Column="2"
                                  IsChecked="{Binding ShowLabel}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Hintergrundfarbe -->
                        <Grid Grid.Column="3" Margin="4,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28"/>
                            <Border Grid.Column="1" Width="20" Height="20" Margin="4,0,0,0"
                                    Background="{Binding BackgroundColor,
                                                 Converter={StaticResource StringToBrushConverter}}"
                                    BorderThickness="1" BorderBrush="#FF555555" CornerRadius="3"/>
                        </Grid>

                        <!-- Rahmenfarbe -->
                        <Grid Grid.Column="4" Margin="4,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28"/>
                            <Border Grid.Column="1" Width="20" Height="20" Margin="4,0,0,0"
                                    Background="{Binding BorderColor,
                                                 Converter={StaticResource StringToBrushConverter}}"
                                    BorderThickness="1" BorderBrush="#FF555555" CornerRadius="3"/>
                        </Grid>

                        <!-- Breite (relative Gewichtung) -->
                        <TextBox Grid.Column="5"
                                 Text="{Binding Width, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                 Width="58" Height="28" HorizontalAlignment="Center"
                                 TextAlignment="Center"/>

                        <!-- Löschen -->
                        <Button Grid.Column="6" Width="26" Height="26" Content="✕"
                                Style="{StaticResource IconButton}"
                                Tag="{Binding}"
                                Click="Delete_Click"
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- + Neue Zone -->
        <Button Content="+ Neue Zone"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Left"
                Margin="0,12,0,0"
                Click="AddZone_Click"/>

        <!-- ── Separator ─────────────────────────────────────────────── -->
        <Rectangle Height="1" Fill="#FF333333" Margin="0,20"/>

        <!-- Schließen -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Schließen"
                    Style="{StaticResource PrimaryButton}"
                    Click="Close_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
