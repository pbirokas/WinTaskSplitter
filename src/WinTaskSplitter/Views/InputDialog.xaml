<Window x:Class="WinTaskSplitter.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTaskSplitter"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF2A2A2A"
        Foreground="White">
    <StackPanel Margin="16">
        <TextBlock x:Name="LabelText" Margin="0,0,0,6" Foreground="#CCFFFFFF"/>
        <TextBox  x:Name="InputBox"
                  Background="#FF3A3A3A" Foreground="White"
                  BorderBrush="#FF555555" Padding="4"
                  KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     Width="72" Margin="0,0,8,0" Click="Ok_Click"
                    Background="#FF3A6A3A" Foreground="White" BorderThickness="0" Padding="4,6"/>
            <Button Content="Abbrechen" Width="88" Click="Cancel_Click"
                    Background="#FF4A4A4A" Foreground="White" BorderThickness="0" Padding="4,6"/>
        </StackPanel>
    </StackPanel>
</Window>
