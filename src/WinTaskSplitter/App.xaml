<Application x:Class="WinTaskSplitter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WinTaskSplitter.Converters"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:ColorOpacityToBrushConverter x:Key="ColorOpacityToBrushConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NullToInverseVisibilityConverter x:Key="NullToInverseVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Application.Resources>

</Application>
